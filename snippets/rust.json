  "binary search custom": {
    "prefix": "bsearchc",
    "body": [
      "let mut lo = ${1:0i64};",
      "let mut hi = ${2:n as i64};",
      "while lo < hi {",
      "    let mid = lo + (hi - lo) / 2;",
      "    if ${3:check(mid)} {",
      "        hi = mid;",
      "    } else {",
      "        lo = mid + 1;",
      "    }",
      "}",
      "// lo is the answer"
    ],
    "description": "Custom binary search template"
  },

  "GCD": {
    "prefix": "gcd",
    "body": [
      "fn gcd(a: i64, b: i64) -> i64 {",
      "    if b == 0 { a } else { gcd(b, a % b) }",
      "}"
    ],
    "description": "GCD function"
  },

  "LCM": {
    "prefix": "lcm",
    "body": [
      "fn lcm(a: i64, b: i64) -> i64 {",
      "    a / gcd(a, b) * b",
      "}"
    ],
    "description": "LCM function (uses gcd)"
  },

  "modpow": {
    "prefix": "modpow",
    "body": [
      "fn modpow(mut base: i64, mut exp: i64, modulus: i64) -> i64 {",
      "    let mut result = 1i64;",
      "    base %= modulus;",
      "    while exp > 0 {",
      "        if exp % 2 == 1 {",
      "            result = result * base % modulus;",
      "        }",
      "        exp /= 2;",
      "        base = base * base % modulus;",
      "    }",
      "    result",
      "}"
    ],
    "description": "Modular exponentiation"
  },

  "prefix sum": {
    "prefix": "prefix",
    "body": [
      "let mut prefix = vec![0i64; ${1:v}.len() + 1];",
      "for (i, &x) in ${1:v}.iter().enumerate() {",
      "    prefix[i + 1] = prefix[i] + x;",
      "}"
    ],
    "description": "Build prefix sum array"
  },

  "union find": {
    "prefix": "uf",
    "body": [
      "struct UnionFind {",
      "    parent: Vec<usize>,",
      "    rank: Vec<usize>,",
      "}",
      "",
      "impl UnionFind {",
      "    fn new(n: usize) -> Self {",
      "        Self { parent: (0..n).collect(), rank: vec![0; n] }",
      "    }",
      "",
      "    fn find(&mut self, x: usize) -> usize {",
      "        if self.parent[x] != x {",
      "            self.parent[x] = self.find(self.parent[x]);",
      "        }",
      "        self.parent[x]",
      "    }",
      "",
      "    fn union(&mut self, x: usize, y: usize) -> bool {",
      "        let (rx, ry) = (self.find(x), self.find(y));",
      "        if rx == ry { return false; }",
      "        match self.rank[rx].cmp(&self.rank[ry]) {",
      "            std::cmp::Ordering::Less => self.parent[rx] = ry,",
      "            std::cmp::Ordering::Greater => self.parent[ry] = rx,",
      "            std::cmp::Ordering::Equal => { self.parent[ry] = rx; self.rank[rx] += 1; }",
      "        }",
      "        true",
      "    }",
      "}"
    ],
    "description": "Union-Find (DSU) with path compression and union by rank"
  },

  "graph adjacency list": {
    "prefix": "graph",
    "body": [
      "let n = ${1:10};",
      "let mut adj: Vec<Vec<usize>> = vec![vec![]; n];",
      "// for weighted: Vec<Vec<(usize, i64)>>",
      "adj[${2:u}].push(${3:v});",
      "adj[${3:v}].push(${2:u}); // undirected"
    ],
    "description": "Adjacency list graph"
  },

  "BFS": {
    "prefix": "bfs",
    "body": [
      "let mut dist = vec![usize::MAX; n];",
      "let mut queue = std::collections::VecDeque::new();",
      "dist[${1:start}] = 0;",
      "queue.push_back(${1:start});",
      "",
      "while let Some(u) = queue.pop_front() {",
      "    for &v in &adj[u] {",
      "        if dist[v] == usize::MAX {",
      "            dist[v] = dist[u] + 1;",
      "            queue.push_back(v);",
      "        }",
      "    }",
      "}"
    ],
    "description": "BFS shortest path"
  },

  "DFS iterative": {
    "prefix": "dfs",
    "body": [
      "let mut visited = vec![false; n];",
      "let mut stack = vec![${1:start}];",
      "",
      "while let Some(u) = stack.pop() {",
      "    if visited[u] { continue; }",
      "    visited[u] = true;",
      "    for &v in &adj[u] {",
      "        if !visited[v] {",
      "            stack.push(v);",
      "        }",
      "    }",
      "}"
    ],
    "description": "DFS iterative"
  },

  "Dijkstra": {
    "prefix": "dijkstra",
    "body": [
      "let mut dist = vec![i64::MAX; n];",
      "let mut heap = std::collections::BinaryHeap::new();",
      "dist[${1:src}] = 0;",
      "heap.push(std::cmp::Reverse((0i64, ${1:src})));",
      "",
      "while let Some(std::cmp::Reverse((d, u))) = heap.pop() {",
      "    if d > dist[u] { continue; }",
      "    for &(v, w) in &adj[u] {",
      "        if dist[u] + w < dist[v] {",
      "            dist[v] = dist[u] + w;",
      "            heap.push(std::cmp::Reverse((dist[v], v)));",
      "        }",
      "    }",
      "}"
    ],
    "description": "Dijkstra shortest paths"
  },

