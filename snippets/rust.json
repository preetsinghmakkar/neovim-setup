{
  "CP main (fast I/O)": {
    "prefix": "cpmain",
    "body": [
      "use std::io::{self, BufRead, Write};",
      "",
      "fn solve<W: Write>(input: &[&str], out: &mut W) {",
      "    let mut iter = input.iter();",
      "    let _n: usize = iter.next().unwrap().trim().parse().unwrap();",
      "    ${1:// solve here}",
      "    writeln!(out, \"\").unwrap();",
      "}",
      "",
      "fn main() {",
      "    let stdin = io::stdin();",
      "    let stdout = io::stdout();",
      "    let mut out = io::BufWriter::new(stdout.lock());",
      "    let lines: Vec<String> = stdin.lock().lines().map(|l| l.unwrap()).collect();",
      "    let refs: Vec<&str> = lines.iter().map(|s| s.as_str()).collect();",
      "    solve(&refs, &mut out);",
      "}"
    ],
    "description": "CP main with fast buffered I/O"
  },

  "CP main (multi-test)": {
    "prefix": "cpmt",
    "body": [
      "use std::io::{self, BufRead, Write};",
      "",
      "fn solve<W: Write>(input: &[&str], out: &mut W) {",
      "    ${1:// solve one test case}",
      "    writeln!(out, \"\").unwrap();",
      "}",
      "",
      "fn main() {",
      "    let stdin = io::stdin();",
      "    let stdout = io::stdout();",
      "    let mut out = io::BufWriter::new(stdout.lock());",
      "    let lines: Vec<String> = stdin.lock().lines().map(|l| l.unwrap()).collect();",
      "    let refs: Vec<&str> = lines.iter().map(|s| s.as_str()).collect();",
      "",
      "    let t: usize = refs[0].trim().parse().unwrap();",
      "    let mut i = 1;",
      "    for _ in 0..t {",
      "        let n: usize = refs[i].trim().parse().unwrap();",
      "        solve(&refs[i..i + n + 1], &mut out);",
      "        i += n + 1;",
      "    }",
      "}"
    ],
    "description": "CP main with multiple test cases"
  },

