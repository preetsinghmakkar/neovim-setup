    "body": "auto it = upper_bound(${1:v}.begin(), ${1:v}.end(), ${2:target});",
    "description": "upper_bound (first > target)"
  },

  "binary search custom": {
    "prefix": "bsearch",
    "body": [
      "int lo = ${1:0}, hi = ${2:n} - 1;",
      "while (lo <= hi) {",
      "    int mid = lo + (hi - lo) / 2;",
      "    if (${3:check(mid)}) {",
      "        hi = mid - 1;",
      "    } else {",
      "        lo = mid + 1;",
      "    }",
      "}",
      "// lo is the answer"
    ],
    "description": "Custom binary search"
  },

  "GCD": {
    "prefix": "gcd",
    "body": "__gcd(${1:a}, ${2:b})",
    "description": "GCD using __gcd"
  },

  "prefix sum": {
    "prefix": "prefix",
    "body": [
      "vector<${1:long long}> prefix(${2:v}.size() + 1, 0);",
      "for (int i = 0; i < (int)${2:v}.size(); i++)",
      "    prefix[i + 1] = prefix[i] + ${2:v}[i];"
    ],
    "description": "Build prefix sum array"
  },

  "union find": {
    "prefix": "uf",
    "body": [
      "struct UnionFind {",
      "    vector<int> parent, rank;",
      "    UnionFind(int n) : parent(n), rank(n, 0) { iota(parent.begin(), parent.end(), 0); }",
      "    int find(int x) { return parent[x] == x ? x : parent[x] = find(parent[x]); }",
      "    bool unite(int x, int y) {",
      "        x = find(x); y = find(y);",
      "        if (x == y) return false;",
      "        if (rank[x] < rank[y]) swap(x, y);",
      "        parent[y] = x;",
      "        if (rank[x] == rank[y]) rank[x]++;",
      "        return true;",
      "    }",
      "};"
    ],
    "description": "Union-Find (DSU)"
  },

  "graph adjacency list": {
    "prefix": "graph",
    "body": [
      "int n = ${1:10};",
      "vector<vector<int>> adj(n);",
      "// for weighted: vector<vector<pair<int,int>>> adj(n);",
      "adj[${2:u}].push_back(${3:v});",
      "adj[${3:v}].push_back(${2:u}); // undirected"
    ],
    "description": "Adjacency list graph"
  },

  "BFS": {
    "prefix": "bfs",
    "body": [
      "vector<int> dist(n, -1);",
      "queue<int> q;",
      "dist[${1:start}] = 0;",
      "q.push(${1:start});",
      "while (!q.empty()) {",
      "    int u = q.front(); q.pop();",
      "    for (int v : adj[u]) {",
      "        if (dist[v] == -1) {",
      "            dist[v] = dist[u] + 1;",
      "            q.push(v);",
      "        }",
      "    }",
      "}"
    ],
    "description": "BFS shortest path"
  },

  "DFS recursive": {
    "prefix": "dfs",
    "body": [
      "vector<bool> visited(n, false);",
      "function<void(int)> dfs = [&](int u) {",
      "    visited[u] = true;",
      "    for (int v : adj[u])",
      "        if (!visited[v]) dfs(v);",
      "};",
      "dfs(${1:start});"
    ],
    "description": "DFS recursive with lambda"
  },

  "Dijkstra": {
    "prefix": "dijkstra",
    "body": [
      "vector<long long> dist(n, LLONG_MAX);",
      "priority_queue<pair<long long,int>, vector<pair<long long,int>>, greater<>> pq;",
      "dist[${1:src}] = 0;",
      "pq.push({0, ${1:src}});",
      "while (!pq.empty()) {",
      "    auto [d, u] = pq.top(); pq.pop();",
      "    if (d > dist[u]) continue;",
      "    for (auto [v, w] : adj[u]) {",
      "        if (dist[u] + w < dist[v]) {",
      "            dist[v] = dist[u] + w;",
      "            pq.push({dist[v], v});",
      "        }",
      "    }",
      "}"
    ],
    "description": "Dijkstra shortest paths"
  },

